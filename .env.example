# Commit FHL — Required Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env — it contains secrets

# ── Azure AD App Registration ────────────────────────────────────────────────
TENANT_ID=your-tenant-id-here
CLIENT_ID=your-client-id-here
CLIENT_SECRET=your-client-secret-here

# ── Azure OpenAI ─────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ── Azure Storage (use Azurite for local dev) ─────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=UseDevelopmentStorage=true

# ── Azure App Configuration (Feature Flags) ──────────────────────────────────
AZURE_APP_CONFIG_CONNECTION_STRING=your-app-config-connection-string
# Or use Managed Identity endpoint for deployed environments:
# AZURE_APP_CONFIG_ENDPOINT=https://your-resource.azconfig.io

# ── Application Insights ──────────────────────────────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=your-key-here

# ── Teams & Bot Configuration ──────────────────────────────────────────────────
TEAMS_APP_ID=your-teams-app-id
BOT_ID=your-bot-id
BOT_PASSWORD=your-bot-password

# ── ADO (Azure DevOps) — Optional, used by adoExtractor ──────────────────────
ADO_ORG_URL=https://dev.azure.com/your-org
ADO_PAT=your-personal-access-token

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Psychology & UX Feature Flags (dev overrides) ───────────────────────────
# These are managed by Azure App Configuration in non-dev environments
# Uncomment to force-enable locally:
# FEATURE_FLAG_PSYCHOLOGY_LAYER=true
# FEATURE_FLAG_DELIVERY_SCORE=true
# FEATURE_FLAG_STREAK_TRACKING=true
