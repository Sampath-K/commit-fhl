{
  "$schema": "https://stryker-mutator.io/schemas/stryker-core.json",
  "packageManager": "npm",
  "reporters": ["html", "clear-text", "progress"],
  "testRunner": "jest",
  "jest": {
    "projectType": "custom",
    "configFile": "tests/jest.config.ts"
  },
  "checkers": ["typescript"],
  "tsconfigFile": "src/app/tsconfig.json",
  "mutate": [
    "src/app/src/**/*.{ts,tsx}",
    "!src/app/src/**/*.d.ts",
    "!src/app/src/main.tsx",
    "!src/app/src/i18n.ts",
    "!src/app/src/locales/**",
    "!src/app/src/config/psychology.config.ts"
  ],
  "thresholds": {
    "high": 80,
    "low": 70,
    "break": 70
  },
  "timeoutMS": 60000
}
